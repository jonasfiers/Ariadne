<?xml version="1.0" encoding="utf-8"?>
<!--
  Seed file for AutoGenerateBindingRedirects. MSBuild rewrites this into
  bin/Release/net472/Ariadne.Package.dll.config with the computed <bindingRedirect> entries.
  See Ariadne.Package.csproj for why those redirects are documentation rather than a fix.
-->
<configuration>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1" />
  </runtime>
</configuration>
